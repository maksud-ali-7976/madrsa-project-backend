{
  "name": "bun-sarovar-test",
  "version": "1.0.60",
  "engines": {
    "bun": "1.2.19"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./build --sourcemap=external --target=node --external pdfkit --external node-appwrite --external node-fetch-native-with-agent",
    "start": "NODE_ENV=production bun build/index.js",
    "test": "bun --watch src/test/test.ts",
    "mtgen": "bun run --watch src/utils/mongoose-ts-gen.ts",
    "push": "bun run build && git add . && git commit -m 'bug fixes' && git push origin main",
    "deploy": "git checkout main && git merge test && git push origin main && git checkout test"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/html": "^1.4.2",
    "@elysiajs/static": "^1.1.1",
    "@elysiajs/swagger": "^1.1.6",
    "@typegoose/typegoose": "^12.9.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "agenda": "^5.0.0",
    "agora-token": "^2.0.3",
    "apple-signin-auth": "^2.0.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "consola": "^3.4.0",
    "cron": "^3.2.1",
    "dotenv": "^16.4.6",
    "elysia": "^1.1.25",
    "elysia-helmet": "^1.0.2",
    "firebase": "^10.14.1",
    "form-data": "^4.0.1",
    "google-auth-library": "^10.2.1",
    "ioredis": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^8.8.3",
    "node-appwrite": "^14.1.0",
    "nodemailer": "^6.9.16",
    "otpless-node-js-auth-sdk": "^1.0.8",
    "pdfkit": "^0.16.0",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.8",
    "@types/qrcode": "^1.5.5",
    "@webpack-cli/generators": "^3.0.7",
    "bun-types": "latest",
    "mongoose-tsgen": "^9.5.0",
    "webpack-cli": "^5.1.4"
  },
  "module": "src/index.js"
}
